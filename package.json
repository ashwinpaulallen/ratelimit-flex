{
  "name": "ratelimit-flex",
  "version": "1.4.1",
  "description": "Flexible rate limiting for Node.js (Express, Fastify, sliding window, token bucket)",
  "license": "MIT",
  "keywords": [
    "rate-limiter",
    "express",
    "fastify",
    "sliding-window",
    "token-bucket",
    "middleware",
    "rate-limiting",
    "metrics",
    "observability",
    "prometheus",
    "opentelemetry",
    "monitoring",
    "histogram"
  ],
  "author": "Ashwin Paul Allen",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "default": "./dist/index.js"
    },
    "./fastify": {
      "import": {
        "types": "./dist/fastify.d.ts",
        "default": "./dist/fastify.js"
      },
      "require": {
        "types": "./dist/cjs/fastify.d.ts",
        "default": "./dist/cjs/fastify.js"
      },
      "default": "./dist/fastify.js"
    }
  },
  "peerDependencies": {
    "@types/express": "*",
    "express": "^4.18.0 || ^5.0.0",
    "fastify": "^4.28.0 || ^5.0.0",
    "fastify-plugin": "^4.5.1 || ^5.0.0",
    "ioredis": "^5.0.0",
    "@opentelemetry/api": "^1.0.0",
    "prom-client": "^15.0.0"
  },
  "peerDependenciesMeta": {
    "@types/express": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "fastify-plugin": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "build": "npm run sync-version && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "express": "^5.2.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "prettier": "^3.8.1",
    "prom-client": "^15.1.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
